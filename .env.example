# Copy to .env.local and fill in as needed.

# Optional: forward waitlist/contact leads to an external webhook
# (e.g. a Make/Zapier/custom endpoint). Leave blank to store leads locally
# in .leads/leads.jsonl instead.
LEADS_WEBHOOK_URL=

# ---- Stripe (required for the crowdfunding /api/checkout flow) ----
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret for /api/stripe-webhook.
# Create a webhook endpoint in the Stripe dashboard for the
# "checkout.session.completed" event, then paste the signing secret here.
# Local dev: `stripe listen --forward-to localhost:3000/api/stripe-webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
